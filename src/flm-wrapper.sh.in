#!/bin/bash
# Wrapper for the FLM portable build.
# The portable tree is self-contained: the real binary (flm-real) and all of its
# bundled shared libraries (libhrx + the NPU engine .so) live under ./lib next to
# this script. The engine libs already carry an $ORIGIN-relative RUNPATH, so this
# wrapper only needs to make ./lib discoverable as a belt-and-suspenders and then
# exec the real binary from the script's own directory.

# Directory containing this script (and the bundled tree).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Make the bundled libraries resolvable at runtime.
export LD_LIBRARY_PATH="$SCRIPT_DIR/lib:$LD_LIBRARY_PATH"

# Execute the real binary, forwarding all arguments.
exec "$SCRIPT_DIR/flm-real" "$@"
