# Pinned HRX (amdxdna) *public package* release consumed by the HRX runtime path.
#
# NOTE: After XADX removal, FLM consumes HRX via find_package(hrx) from the public
# package (CMake package config + hrx.dll/import lib + public headers), NOT the
# former HRX_DIR (source) + HRX_BUILD (build tree) layout. The fetch scripts now
# expose the package prefix via CMAKE_PREFIX_PATH.
#
# TODO(release): the Linux agent builds `hrx_no_xadx` off amdxdna-hal-native-rel
# (merged with the Windows CMake packaging flow, amdxdna HAL ON) and publishes
# both OS packages. Fill in the final REPO/TAG/ASSET/SHA256 once that release
# exists. Values below are placeholders and WILL NOT resolve yet.
HRX_RELEASE_REPO="Abhishek-Varma/hrx-system"
HRX_RELEASE_TAG="TODO-set-after-hrx-public-release"

# Linux artifact (public package; fetch-hrx-release.sh consumes ASSET/SHA256).
HRX_RELEASE_ASSET="hrx-public-linux-x86_64-TODO.tar.zst"
HRX_RELEASE_SHA256="TODO-set-after-hrx-public-release"

# Windows artifact (public package; fetch-hrx-release.ps1 consumes the .zip).
HRX_RELEASE_ASSET_WINDOWS="hrx-public-windows-x86_64-TODO.zip"
HRX_RELEASE_SHA256_WINDOWS="TODO-set-after-hrx-public-release"
